# Database Configuration
# IMPORTANT: If you previously ran this with a different password, you MUST delete the old volume:
#   docker-compose down -v
#   docker volume rm indian_stock_tracker_postgres_data
# Then restart with: docker-compose up -d
#
# PostgreSQL only uses these credentials on FIRST startup. Changing them after
# the volume exists has no effect unless you delete the volume.
DB_USER=stockuser
DB_PASSWORD=stockpass
DB_NAME=stocktracker

# API Keys (Get free keys from these services)
NEWS_API_KEY=your_newsapi_key_here          # https://newsapi.org (100 req/day free)
GROQ_API_KEY=your_groq_key_here             # https://console.groq.com (free tier)
ALPHA_VANTAGE_KEY=your_alphavantage_key     # https://www.alphavantage.co (25 req/day free)

# Telegram Alerts (Optional but recommended)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Security
SECRET_KEY=change-this-to-a-random-string-32-chars-long
ENVIRONMENT=production
